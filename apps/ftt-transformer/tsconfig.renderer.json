{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/renderer/src/**/*", "src/renderer/src/**/*.tsx"]
}
